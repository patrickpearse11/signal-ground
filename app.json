{
  "expo": {
    "name": "Signal + Ground",
    "slug": "signal-ground",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "signal-ground",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A2744"
    },
    "ios": {
      "bundleIdentifier": "com.signalandground.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.signalandground.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A2744"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
